<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>共同記帳 Web App</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-4 md:p-8">
    <div id="app" class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-center mb-8 text-blue-600">共同記帳系統</h1>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-1 space-y-6">
                <div class="bg-white p-6 rounded-lg shadow">
                    <h2 class="text-xl font-semibold mb-4">成員管理</h2>
                    <div class="flex mb-4">
                        <input v-model="this.newMemberName" type="text" placeholder="成員姓名" class="border p-2 rounded-l w-full outline-none focus:border-blue-500">
                        <button @click="this.addMember" class="bg-blue-500 text-white px-4 py-2 rounded-r hover:bg-blue-600">加入</button>
                    </div>
                    <ul class="space-y-2">
                        <li v-for="m in this.members" :key="m.id" class="flex justify-between items-center bg-gray-50 p-2 rounded">
                            <span>{{ m.name }}</span>
                            <span :class="this.getBalanceClass(m.id)" class="font-mono font-bold">
                                {{ this.calculateBalance(m.id) }}
                            </span>
                        </li>
                    </ul>
                </div>

                <div class="bg-white p-6 rounded-lg shadow">
                    <h2 class="text-xl font-semibold mb-4">新增帳目</h2>
                    <div class="space-y-4">
                        <input v-model.number="this.newRecord.amount" type="number" placeholder="金額" class="border p-2 rounded w-full">
                        <input v-model="this.newRecord.desc" type="text" placeholder="用途 (例如: 晚餐)" class="border p-2 rounded w-full">
                        
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">誰先墊錢？</label>
                            <select v-model="this.newRecord.payerId" class="border p-2 rounded w-full">
                                <option v-for="m in this.members" :value="m.id">{{ m.name }}</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-gray-600 mb-1">誰要分擔？</label>
                            <div class="flex flex-wrap gap-2">
                                <button v-for="m in this.members" 
                                    @click="this.toggleParticipant(m.id)"
                                    :class="this.newRecord.participantIds.includes(m.id) ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-700'"
                                    class="px-3 py-1 rounded-full text-sm transition">
                                    {{ m.name }}
                                </button>
                            </div>
                        </div>

                        <button @click="this.addRecord" class="w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700">送出帳目</button>
                    </div>
                </div>
            </div>

            <div class="md:col-span-2">
                <div class="bg-white p-6 rounded-lg shadow min-h-full">
                    <h2 class="text-xl font-semibold mb-4">帳目明細</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="border-b">
                                    <th class="py-2">描述</th>
                                    <th class="py-2">總額</th>
                                    <th class="py-2">墊錢人</th>
                                    <th class="py-2">分擔成員</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="r in this.records" :key="r.id" class="border-b hover:bg-gray-50 text-sm">
                                    <td class="py-3">{{ r.desc }}</td>
                                    <td class="py-3 font-bold">${{ r.amount }}</td>
                                    <td class="py-3 text-blue-600">{{ this.getMemberName(r.payerId) }}</td>
                                    <td class="py-3 text-gray-500 text-xs">
                                        {{ r.participantIds.map(id => this.getMemberName(id)).join(', ') }}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div v-if="this.records.length === 0" class="text-center text-gray-400 py-10">尚無帳目記錄</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const { createApp } = Vue;

        createApp({
            data() {
                return {
                    members: [
                        { id: 1, name: '小明' },
                        { id: 2, name: '小華' }
                    ],
                    records: [],
                    newMemberName: '',
                    newRecord: {
                        amount: null,
                        desc: '',
                        payerId: 1,
                        participantIds: [1, 2]
                    }
                }
            },
            methods: {
                addMember() {
                    if (this.newMemberName.trim()) {
                        this.members.push({
                            id: Date.now(),
                            name: this.newMemberName
                        });
                        this.newMemberName = '';
                    }
                },
                toggleParticipant(id) {
                    const index = this.newRecord.participantIds.indexOf(id);
                    if (index > -1) {
                        this.newRecord.participantIds.splice(index, 1);
                    } else {
                        this.newRecord.participantIds.push(id);
                    }
                },
                addRecord() {
                    if (this.newRecord.amount > 0 && this.newRecord.participantIds.length > 0) {
                        this.records.unshift({
                            id: Date.now(),
                            ...JSON.parse(JSON.stringify(this.newRecord))
                        });
                        this.newRecord.amount = null;
                        this.newRecord.desc = '';
                    }
                },
                getMemberName(id) {
                    const member = this.members.find(m => m.id === id);
                    return member ? member.name : 'Unknown';
                },
                calculateBalance(memberId) {
                    let balance = 0;
                    this.records.forEach(r => {
                        // 如果是墊錢人，增加「應收」金額
                        if (r.payerId === memberId) {
                            balance += r.amount;
                        }
                        // 如果在承擔名單中，扣除「應付」金額 (總額 / 承擔人數)
                        if (r.participantIds.includes(memberId)) {
                            balance -= (r.amount / r.participantIds.length);
                        }
                    });
                    return balance.toFixed(0);
                },
                getBalanceClass(id) {
                    const balance = this.calculateBalance(id);
                    if (balance > 0) return 'text-green-600';
                    if (balance < 0) return 'text-red-600';
                    return 'text-gray-400';
                }
            }
        }).mount('#app');
    </script>
</body>
</html>
